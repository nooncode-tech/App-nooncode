NOON_ENABLE_SUPABASE_AUTH=false
# Leave blank until Phase 1A auth is intentionally enabled.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NOON_SEED_DEFAULT_PASSWORD=

# Stripe - use test keys (sk_test_...) during development
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Required for Maxwell server-side AI routes.
OPENAI_API_KEY=

# Optional until v0-backed prototype generation is intentionally enabled.
V0_API_KEY=

# Website <-> App server webhooks. Do not expose this secret in client bundles.
NOON_WEBSITE_WEBHOOK_SECRET=
NOON_WEBSITE_REVIEW_DECISION_WEBHOOK_URL=
CRON_SECRET=
