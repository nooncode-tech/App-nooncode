# =============================================================================
# Auth (Phase 1A — Supabase auth + RLS)
# =============================================================================

# Toggle real Supabase auth. Set to true once Phase 1A is wired up; while
# false the app runs in mock-auth mode and the SUPABASE_* keys below are
# not read.
NOON_ENABLE_SUPABASE_AUTH=false

# Always required. Used for absolute URLs in OAuth redirects and email links.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Required when NOON_ENABLE_SUPABASE_AUTH=true.
# From Supabase dashboard -> Project Settings -> API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Required for server-side admin operations (earnings credit/consolidate,
# wallet RPCs, seed scripts, webhooks bypassing RLS). NEVER expose in client
# bundles. From Supabase dashboard -> Project Settings -> API -> service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Required only by scripts/seed-phase-*-users.ts. Leave blank in normal use.
NOON_SEED_DEFAULT_PASSWORD=

# =============================================================================
# Stripe (Phase 9 payments + Phase 17 webhook ledger)
# =============================================================================

# Required for any payment flow. Use test keys (sk_test_..., pk_test_...) in
# dev/staging; live keys (sk_live_..., pk_live_...) ONLY on production Vercel.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Required for /api/stripe/webhook (Phase 17 webhook event ledger).
# Generate in Stripe dashboard -> Developers -> Webhooks. Different per env.
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# AI providers
# =============================================================================

# Required for Maxwell server-side chat (Phase 16 lead engine + global Maxwell).
OPENAI_API_KEY=

# Optional until Phase 5b v0-backed prototype generation is enabled.
# From v0.dev account settings.
V0_API_KEY=

# =============================================================================
# Website <-> App integration (Phase 14)
# =============================================================================

# Required for Phase 14 website inbound webhooks. Shared secret used to verify
# signed payloads coming from the marketing site. NEVER expose in client bundles.
NOON_WEBSITE_WEBHOOK_SECRET=

# Required for Phase 14 review-decision callbacks. Full URL the App POSTs to
# when a review action is taken on a website-submitted lead.
NOON_WEBSITE_REVIEW_DECISION_WEBHOOK_URL=

# B15 (Phase 20a) transport-level webhook ledger kill switch. Default ON: any
# value other than the literal "false" (case-insensitive) enables the ledger.
# Set to "false" to disable the inbound webhook idempotency ledger on
# /api/integrations/website/inbound-proposal and
# /api/integrations/website/payment-confirmed (emergency rollback path —
# reverts route behavior to pre-B15 app-layer-only idempotency). See ADR-016.
WEBSITE_WEBHOOK_LEDGER_ENABLED=true

# G23 (Phase 3 R5 / ADR-027 D5) outbound webhook retry-with-backoff kill
# switch. Default ON: any value other than the literal "false"
# (case-insensitive) enables full inline retry (3 attempts, 2s/4s/8s with
# +/- 25% jitter) for proposal_review_decision outbound POSTs.
# Set to "false" to disable the inline retry loop. IMPORTANT: the ledger
# row is STILL written on every dispatch (durability-preserving panic mode
# per ADR-027 D5 option-b). The cron sweeper
# (/api/cron/outbound-webhook-retry) and the admin replay endpoint
# (/api/admin/outbound-webhooks/[eventId]/replay) remain active regardless
# of this flag.
NOON_OUTBOUND_WEBHOOK_RETRY_ENABLED=true

# Required for Vercel Cron route protection. Any sufficiently-random value,
# rotated per environment. Used by /api/cron/* to reject unsigned invocations.
CRON_SECRET=

# Cooling period (days) before pending earnings are consolidated to
# `available_to_withdraw` by the daily cron `/api/cron/consolidate-earnings`.
# Defaults to 7 days when unset or non-positive. Lower values increase the
# refund-after-consolidation hazard (Stripe permits refunds up to 180 days);
# raise to delay payout availability if needed (per ADR-015).
EARNINGS_CONSOLIDATION_COOLING_DAYS=7

# =============================================================================
# Rate limiting — Upstash Redis (B14, FASE 1)
# =============================================================================

# Optional in dev; required in Production for distributed rate limiting.
# Auto-injected when you add the Upstash Redis integration from the Vercel
# Marketplace (Vercel Dashboard -> Storage -> Add). The rate limiter accepts
# either of the two naming conventions Vercel uses, preferring UPSTASH_* when
# both are set:
#   - UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN — standalone Upstash
#     marketplace listing.
#   - KV_REST_API_URL / KV_REST_API_TOKEN — Vercel KV product listing (same
#     Upstash backend under Vercel's KV branding).
# If neither pair is present the rate limiter falls back to an in-memory
# per-process implementation suitable for local dev only.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
KV_REST_API_URL=
KV_REST_API_TOKEN=
